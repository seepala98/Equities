# Copy this file to .env and fill in your values before running docker compose.
# .env is gitignored — never commit real secrets.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=stockdb
POSTGRES_USER=stockuser
POSTGRES_PASSWORD=changeme

# ── Django ───────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=0
# Comma-separated list of origins allowed to call the API (in production)
CORS_ALLOWED_ORIGINS=http://localhost

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── pgAdmin ──────────────────────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=changeme

# ── Airflow ──────────────────────────────────────────────────────────────────
AIRFLOW_WEBSERVER_SECRET_KEY=change-me-airflow-secret
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=changeme
